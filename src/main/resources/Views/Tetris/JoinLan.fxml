<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.net.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<StackPane fx:id="root" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="600.0" minWidth="800.0"
           styleClass="background" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="seda_project.control_alt_defeat.gamebox.Tetris.Controller.JoinLan">
    <stylesheets>
        <URL value="@../../css/stylesheets/MenuStyle.css"/>
        <URL value="@../../css/stylesheets/TetrisMenu.css"/>
        <URL value="@../../css/stylesheets/fontstyle.css"/>
    </stylesheets>
    <VBox alignment="TOP_CENTER" fillWidth="false" layoutX="2.0">
        <HBox alignment="CENTER" spacing="10.0">
            <VBox.margin>
                <Insets top="10.0"/>
            </VBox.margin>
            <Region maxWidth="80.0" minWidth="80.0" prefWidth="80.0"/>
            <VBox fx:id="header" alignment="TOP_CENTER" fillWidth="false" maxHeight="-Infinity"
                  maxWidth="-Infinity" styleClass="box">
                <padding>
                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                </padding>
                <Label alignment="CENTER" contentDisplay="CENTER" maxHeight="-Infinity" maxWidth="-Infinity"
                       styleClass="headerText" text="COFFEE BREAK GAMES" textAlignment="CENTER"
                       textOverrun="CLIP">
                    <font>
                        <Font name="Arial Bold" size="24.0"/>
                    </font>
                </Label>
                <Label alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="normalText"
                       text="Main Menu">
                    <font>
                        <Font size="18.0"/>
                    </font>
                </Label>
            </VBox>
            <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="box">
                <ImageView fx:id="muteButton" fitHeight="80.0" fitWidth="80.0" onMouseClicked="#changeMute" pickOnBounds="true"
                           preserveRatio="true" styleClass="mute">
                    <Image url="@../../Images/others/mute.png"/>
                </ImageView>
            </VBox>
        </HBox>
        <StackPane prefHeight="475.0">
            <padding>
                <Insets top="5.0"/>
            </padding>
            <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="box">
                <padding>
                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                </padding>
                <GridPane hgap="5.0" vgap="5.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity"/>
                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity"/>
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints maxHeight="-Infinity" vgrow="SOMETIMES"/>
                        <RowConstraints maxHeight="-Infinity" vgrow="SOMETIMES"/>
                    </rowConstraints>
                    <Label alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity"
                           text="Your Name:"/>
                    <TextField fx:id="joinPlayerNameTF" maxHeight="-Infinity" maxWidth="-Infinity"
                               promptText="Insert Player 1 Name " GridPane.columnIndex="1"/>
                    <Label text="Your Level:" GridPane.rowIndex="1"/>
                    <ComboBox fx:id="yourLevel" maxHeight="-Infinity" maxWidth="-Infinity"
                              GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                </GridPane>
                <ScrollPane fx:id="scrollPane" fitToWidth="true" maxHeight="-Infinity" maxWidth="-Infinity"
                            styleClass="transparent-scroll">
                    <VBox fx:id="scrollElements" maxHeight="-Infinity" maxWidth="-Infinity"
                          styleClass="transparent-scroll-content"/>
                </ScrollPane>
                <Label fx:id="joinStatus" alignment="CENTER" contentDisplay="CENTER" maxHeight="-Infinity"
                       maxWidth="220.0" textAlignment="CENTER" wrapText="true">
                    <styleClass>
                        <String fx:value="error"/>
                        <String fx:value="box"/>
                    </styleClass>
                    <padding>
                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
                    </padding>
                </Label>
                <HBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity">
                    <StackPane styleClass="button-wrapper">
                        <Button mnemonicParsing="false" onAction="#onBackAction" text="Back">
                            <HBox.margin>
                                <Insets right="10.0"/>
                            </HBox.margin>
                        </Button>
                    </StackPane>
                    <StackPane styleClass="button-wrapper">
                        <Button mnemonicParsing="false" onAction="#onConnectAction" text="Connect">
                            <HBox.margin>
                                <Insets left="10.0"/>
                            </HBox.margin>
                        </Button>
                    </StackPane>
                </HBox>
            </VBox>
        </StackPane>
    </VBox>
</StackPane>