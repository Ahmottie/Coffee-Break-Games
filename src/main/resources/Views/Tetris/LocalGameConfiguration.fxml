<?xml version="1.0" encoding="UTF-8"?>

<!-- Code Block 7 corrected alignment -->
<?import java.lang.*?>
<?import java.net.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<StackPane fx:id="root" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="600.0" minWidth="800.0"
           styleClass="background" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="seda_project.control_alt_defeat.gamebox.Tetris.Controller.LocalGameConfiguration">
    <stylesheets>
        <URL value="@../../css/stylesheets/fontstyle.css"/>
        <URL value="@../../css/stylesheets/MenuStyle.css"/>
        <URL value="@../../css/stylesheets/TetrisMenu.css"/>
    </stylesheets>
    <VBox alignment="TOP_CENTER" fillWidth="false" layoutX="2.0">
        <HBox alignment="CENTER" spacing="10.0">
            <VBox.margin>
                <Insets top="10.0"/>
            </VBox.margin>
            <Region maxWidth="80.0" minWidth="80.0" prefWidth="80.0"/>
            <VBox fx:id="header" alignment="TOP_CENTER" fillWidth="false" maxHeight="-Infinity"
                  maxWidth="-Infinity" styleClass="box">
                <padding>
                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                </padding>
                <Label alignment="CENTER" contentDisplay="CENTER" maxHeight="-Infinity" maxWidth="-Infinity"
                       styleClass="headerText" text="COFFEE BREAK GAMES" textAlignment="CENTER"
                       textOverrun="CLIP">
                    <font>
                        <Font name="Arial Bold" size="24.0"/>
                    </font>
                </Label>
                <Label alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="normalText"
                       text="Main Menu">
                    <font>
                        <Font size="18.0"/>
                    </font>
                </Label>
            </VBox>
            <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="box">
                <ImageView fx:id="muteButton" fitHeight="80.0" fitWidth="80.0" onMouseClicked="#changeMute" pickOnBounds="true"
                           preserveRatio="true" styleClass="mute">
                    <Image url="@../../Images/others/mute.png"/>
                </ImageView>
            </VBox>
        </HBox>
        <StackPane prefHeight="475.0">
            <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="box">
                <padding>
                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                </padding>
                <GridPane alignment="CENTER" hgap="5.0" maxHeight="-Infinity" maxWidth="-Infinity"
                          vgap="5.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity"/>
                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity"/>
                        <ColumnConstraints/>
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints maxHeight="-Infinity" vgrow="SOMETIMES"/>
                        <RowConstraints maxHeight="-Infinity" vgrow="SOMETIMES"/>
                        <RowConstraints maxHeight="4.0" minHeight="4.0" prefHeight="4.0" vgrow="SOMETIMES"/>
                        <RowConstraints maxHeight="-Infinity" vgrow="SOMETIMES"/>
                        <RowConstraints maxHeight="-Infinity" vgrow="SOMETIMES"/>
                    </rowConstraints>
                    <padding>
                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
                    </padding>
                    <Label maxHeight="-Infinity" maxWidth="-Infinity" text="Player 1 Name"/>
                    <TextField fx:id="player1TF" maxHeight="-Infinity" maxWidth="-Infinity"
                               promptText="Insert Player 1 Name " GridPane.columnIndex="1">
                        <GridPane.margin>
                            <Insets right="5.0"/>
                        </GridPane.margin>
                    </TextField>
                    <Label maxHeight="-Infinity" maxWidth="-Infinity" text="Player 2 Name"
                           GridPane.rowIndex="3"/>
                    <TextField fx:id="player2TF" maxHeight="-Infinity" maxWidth="-Infinity"
                               promptText="Insert Player 2 Name" GridPane.columnIndex="1"
                               GridPane.rowIndex="3"/>
                    <Label maxHeight="-Infinity" maxWidth="-Infinity" text="Player 1 Level:"
                           GridPane.rowIndex="1"/>
                    <Label maxHeight="-Infinity" maxWidth="-Infinity" text="Player 2 Level:"
                           GridPane.rowIndex="4"/>
                    <ComboBox fx:id="player1Level" maxHeight="-Infinity" maxWidth="-Infinity"
                              GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    <ComboBox fx:id="player2Level" maxHeight="-Infinity" maxWidth="-Infinity"
                              GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                </GridPane>
                <StackPane maxHeight="-Infinity" maxWidth="-Infinity" styleClass="button-wrapper">
                    <Button maxHeight="-Infinity" maxWidth="-Infinity" mnemonicParsing="false"
                            onAction="#onAdvancedSettingsAction" text="Advanced Settings"/>
                </StackPane>
                <Label fx:id="statusLabel" maxHeight="-Infinity" maxWidth="270.0" wrapText="true">
                    <VBox.margin>
                        <Insets bottom="10.0" top="10.0"/>
                    </VBox.margin>
                    <styleClass>
                        <String fx:value="box"/>
                        <String fx:value="error"/>
                    </styleClass>
                    <padding>
                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
                    </padding>
                </Label>
                <HBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity">
                    <VBox.margin>
                        <Insets bottom="10.0"/>
                    </VBox.margin>
                    <StackPane styleClass="button-wrapper">
                        <Button alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false"
                                onAction="#onBackAction" text="Back">
                            <HBox.margin>
                                <Insets right="10.0"/>
                            </HBox.margin>
                        </Button>
                    </StackPane>
                    <StackPane styleClass="button-wrapper">
                        <Button alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false"
                                onAction="#onStartAction" text="Start Game">
                            <HBox.margin>
                                <Insets left="10.0"/>
                            </HBox.margin>
                        </Button>
                    </StackPane>
                </HBox>
            </VBox>
        </StackPane>
    </VBox>
</StackPane>