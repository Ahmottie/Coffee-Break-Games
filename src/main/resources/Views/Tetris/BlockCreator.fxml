<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ColorPicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.Region?>

<StackPane fx:id="root" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="600.0" minWidth="800.0"
           styleClass="background" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="seda_project.control_alt_defeat.gamebox.Tetris.Controller.BlockController">
    <stylesheets>
        <URL value="@../../css/stylesheets/fontstyle.css"/>
        <URL value="@../../css/stylesheets/MenuStyle.css"/>
        <URL value="@../../css/stylesheets/TetrisMenu.css"/>
    </stylesheets>
    <VBox alignment="TOP_CENTER" fillWidth="false" layoutX="2.0">
        <HBox alignment="CENTER" spacing="10.0">
            <VBox.margin>
                <Insets top="10.0"/>
            </VBox.margin>
            <Region maxWidth="80.0" minWidth="80.0" prefWidth="80.0"/>
            <VBox fx:id="header" alignment="TOP_CENTER" fillWidth="false" maxHeight="-Infinity"
                  maxWidth="-Infinity" styleClass="box">
                <padding>
                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                </padding>
                <Label alignment="CENTER" contentDisplay="CENTER" maxHeight="-Infinity" maxWidth="-Infinity"
                       styleClass="headerText" text="COFFEE BREAK GAMES" textAlignment="CENTER"
                       textOverrun="CLIP">
                    <font>
                        <Font name="Arial Bold" size="24.0"/>
                    </font>
                </Label>
                <Label alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="normalText"
                       text="Main Menu">
                    <font>
                        <Font size="18.0"/>
                    </font>
                </Label>
            </VBox>
            <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="box">
                <ImageView fx:id="muteButton" fitHeight="80.0" fitWidth="80.0" onMouseClicked="#changeMute" pickOnBounds="true"
                           preserveRatio="true" styleClass="mute">
                    <Image url="@../../Images/others/mute.png"/>
                </ImageView>
            </VBox>
        </HBox>
        <StackPane maxHeight="-Infinity" minHeight="450.0" prefHeight="475.0" prefWidth="700.0">
            <VBox.margin>
                <Insets top="10.0"/>
            </VBox.margin>
            <SplitPane dividerPositions="0.3697222222222223" maxHeight="-Infinity" maxWidth="-Infinity"
                       styleClass="box">
                <padding>
                    <Insets bottom="15.0" left="15.0" right="15.0" top="15.0"/>
                </padding>
                <VBox alignment="CENTER" maxWidth="200.0" minWidth="200.0">
                    <ScrollPane fx:id="scrollPane" maxHeight="-Infinity" maxWidth="-Infinity"
                                minHeight="350.0" minWidth="200.0" styleClass="scroller"/>
                    <HBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" spacing="5.0">
                        <VBox.margin>
                            <Insets top="10.0"/>
                        </VBox.margin>
                        <StackPane styleClass="button-wrapper">
                            <Button mnemonicParsing="false" onAction="#onLoadAction"
                                    text="Load">
                                <HBox.margin>
                                    <Insets right="10.0"/>
                                </HBox.margin>
                            </Button>
                        </StackPane>
                        <StackPane styleClass="button-wrapper">
                            <Button mnemonicParsing="false"
                                    onAction="#onDeleteAction" text="Delete">
                                <HBox.margin>
                                    <Insets left="10.0"/>
                                </HBox.margin>
                            </Button>
                        </StackPane>
                    </HBox>
                </VBox>
                <VBox alignment="CENTER" fillWidth="false" maxWidth="450.0" minWidth="450.0"
                      prefWidth="450.0" spacing="5.0">
                    <HBox alignment="CENTER" spacing="3.0">
                        <VBox.margin>
                            <Insets bottom="10.0"/>
                        </VBox.margin>
                        <Label maxHeight="-Infinity" maxWidth="-Infinity" text="Block Color: "/>
                        <ColorPicker fx:id="colorPicker" maxHeight="-Infinity" maxWidth="-Infinity"
                                     onAction="#onColorAction" promptText="Block Color"/>
                    </HBox>
                    <GridPane fx:id="gridPane" alignment="CENTER" gridLinesVisible="true"
                              maxHeight="300.0" maxWidth="300.0" minHeight="300.0" minWidth="300.0"
                              prefHeight="300.0" prefWidth="300.0">
                        <columnConstraints>
                            <ColumnConstraints hgrow="NEVER" maxWidth="75.0" minWidth="75.0"
                                               prefWidth="75.00"/>
                            <ColumnConstraints hgrow="NEVER" maxWidth="75.0" minWidth="75.0"
                                               prefWidth="75.00"/>
                            <ColumnConstraints hgrow="NEVER" maxWidth="75.0" minWidth="75.0"
                                               prefWidth="75.00"/>
                            <ColumnConstraints hgrow="NEVER" maxWidth="75.0" minWidth="75.0"
                                               prefWidth="75.00"/>
                        </columnConstraints>
                        <rowConstraints>
                            <RowConstraints maxHeight="75.0" minHeight="75.0" prefHeight="75.0"
                                            vgrow="NEVER"/>
                            <RowConstraints maxHeight="75.0" minHeight="75.0" prefHeight="75.0"
                                            vgrow="NEVER"/>
                            <RowConstraints maxHeight="75.0" minHeight="75.0" prefHeight="75.0"
                                            vgrow="NEVER"/>
                            <RowConstraints maxHeight="75.0" minHeight="75.0" prefHeight="75.0"
                                            vgrow="NEVER"/>
                        </rowConstraints>
                    </GridPane>
                    <HBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity">
                        <StackPane styleClass="button-wrapper">
                            <Button mnemonicParsing="false" onAction="#onResetAction"
                                    text="Reset">
                                <HBox.margin>
                                    <Insets right="10.0"/>
                                </HBox.margin>
                            </Button>
                        </StackPane>
                        <StackPane styleClass="button-wrapper">
                            <Button mnemonicParsing="false" onAction="#onBackAction"
                                    text="Back">
                                <HBox.margin>
                                    <Insets left="10.0" right="10.0"/>
                                </HBox.margin>
                            </Button>
                        </StackPane>
                        <StackPane styleClass="button-wrapper">
                            <Button fx:id="saveButton" mnemonicParsing="false"
                                    onAction="#onSaveAction" text="Save">
                                <HBox.margin>
                                    <Insets left="10.0"/>
                                </HBox.margin>
                            </Button>
                        </StackPane>
                    </HBox>
                </VBox>
            </SplitPane>
        </StackPane>
    </VBox>
</StackPane>