<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" styleClass="background" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="seda_project.control_alt_defeat.gamebox.Tetris.Controller.BlockController">
    <children>
        <VBox alignment="TOP_CENTER" fillWidth="false" layoutX="2.0" prefHeight="631.0" prefWidth="800.0">
            <children>
                <VBox fx:id="header" fillWidth="false" prefHeight="111.0" prefWidth="622.0" styleClass="box">
                    <children>
                        <Label alignment="CENTER" contentDisplay="CENTER" prefHeight="50.0" prefWidth="800.0" styleClass="headerText" text="COFFEE BREAK GAMES" textAlignment="CENTER" textOverrun="CLIP">
                            <font>
                                <Font name="Arial Bold" size="24.0" />
                            </font>
                        </Label>
                        <Label alignment="CENTER" prefHeight="30.0" prefWidth="800.0" styleClass="normalText" text="Memory Game">
                            <font>
                                <Font size="18.0" />
                            </font>
                        </Label>
                        <Label alignment="CENTER" prefHeight="25.0" prefWidth="800.0" text="Block Creator" />
                    </children>
                </VBox>
            <StackPane maxHeight="450.0" minHeight="450.0" prefHeight="450.0" prefWidth="700.0" styleClass="box">
               <children>
                  <SplitPane dividerPositions="0.3697222222222223" maxWidth="700.0" minWidth="700.0" prefHeight="503.0" prefWidth="700.0" style="-fx-background-color: transparent;">
                     <items>
                        <VBox alignment="CENTER" maxWidth="200.0" minWidth="200.0">
                           <children>
                              <ScrollPane fx:id="scrollPane" prefHeight="447.0" prefWidth="200.0" />
                              <HBox alignment="CENTER">
                                 <children>
                                    <Button mnemonicParsing="false" onAction="#onLoadAction" text="Load">
                                       <HBox.margin>
                                          <Insets right="10.0" />
                                       </HBox.margin>
                                    </Button>
                                    <Button fx:id="deleteButton" mnemonicParsing="false" onAction="#onDeleteAction" text="Delete">
                                       <HBox.margin>
                                          <Insets left="10.0" />
                                       </HBox.margin>
                                    </Button>
                                 </children>
                                 <VBox.margin>
                                    <Insets top="10.0" />
                                 </VBox.margin>
                              </HBox>
                           </children>
                        </VBox>
                        <VBox alignment="CENTER" fillWidth="false" maxWidth="450.0" minWidth="450.0" prefWidth="450.0">
                           <children>
                              <HBox>
                                 <children>
                                    <Label minHeight="40.0" prefHeight="40.0" prefWidth="93.0" text="Block Color: " />
                                    <ColorPicker fx:id="colorPicker" minHeight="40.0" onAction="#onColorAction" prefHeight="40.0" prefWidth="161.0" promptText="Block Color" styleClass="black" />
                                 </children>
                                 <VBox.margin>
                                    <Insets bottom="10.0" />
                                 </VBox.margin>
                              </HBox>
                              <GridPane fx:id="gridPane" alignment="CENTER" gridLinesVisible="true" maxHeight="300.0" maxWidth="300.0" minHeight="300.0" minWidth="300.0" prefHeight="300.0" prefWidth="300.0">
                                <columnConstraints>
                                    <ColumnConstraints hgrow="NEVER" maxWidth="75.0" minWidth="75.0" prefWidth="75.00" />
                                    <ColumnConstraints hgrow="NEVER" maxWidth="75.0" minWidth="75.0" prefWidth="75.00" />
                                  <ColumnConstraints hgrow="NEVER" maxWidth="75.0" minWidth="75.0" prefWidth="75.00" />
                                  <ColumnConstraints hgrow="NEVER" maxWidth="75.0" minWidth="75.0" prefWidth="75.00" />
                                </columnConstraints>
                                <rowConstraints>
                                  <RowConstraints maxHeight="75.0" minHeight="75.0" prefHeight="75.0" vgrow="NEVER" />
                                  <RowConstraints maxHeight="75.0" minHeight="75.0" prefHeight="75.0" vgrow="NEVER" />
                                    <RowConstraints maxHeight="75.0" minHeight="75.0" prefHeight="75.0" vgrow="NEVER" />
                                  <RowConstraints maxHeight="75.0" minHeight="75.0" prefHeight="75.0" vgrow="NEVER" />
                                </rowConstraints>
                              </GridPane>
                              <HBox alignment="CENTER" prefHeight="58.0" prefWidth="286.0">
                                 <children>
                                    <Button mnemonicParsing="false" onAction="#onResetAction" text="Reset">
                                       <HBox.margin>
                                          <Insets right="10.0" />
                                       </HBox.margin>
                                    </Button>
                                    <Button mnemonicParsing="false" onAction="#onBackAction" text="Back">
                                       <HBox.margin>
                                          <Insets left="10.0" right="10.0" />
                                       </HBox.margin>
                                    </Button>
                                    <Button fx:id="saveButton" mnemonicParsing="false" onAction="#onSaveAction" text="Save">
                                       <HBox.margin>
                                          <Insets left="10.0" />
                                       </HBox.margin>
                                    </Button>
                                 </children></HBox>
                           </children>
                        </VBox>
                     </items>
                     <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                     </padding>
                  </SplitPane>
               </children>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </StackPane>
            </children>
        </VBox>
    </children>

    <stylesheets>
        <URL value="@../../css/stylesheets/fontstyle.css" />
        <URL value="@../../css/stylesheets/MenuStyle.css" />
        <URL value="@../../css/stylesheets/TetrisMenu.css" />
    </stylesheets>
</AnchorPane>
