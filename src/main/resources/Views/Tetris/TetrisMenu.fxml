<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane fx:id="root" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="600.0" minWidth="800.0" styleClass="background" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="seda_project.control_alt_defeat.gamebox.Tetris.Controller.TetrisMenu">
    <stylesheets>
        <URL value="@../../css/stylesheets/MenuStyle.css" />
        <URL value="@../../css/stylesheets/TetrisMenu.css" />
        <URL value="@../../css/stylesheets/fontstyle.css" />
    </stylesheets>
    <VBox alignment="TOP_CENTER">
        <fx:include source="../TopBar.fxml" />
            <VBox fx:id="header" alignment="TOP_CENTER" fillWidth="false" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="box">
                <padding>
                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                </padding>
                <Label alignment="CENTER" contentDisplay="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="headerText" text="COFFEE BREAK GAMES" textAlignment="CENTER" textOverrun="CLIP">
                    <font>
                        <Font name="Arial Bold" size="24.0" />
                    </font>
                </Label>
                <Label alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="normalText" text="Main Menu">
                    <font>
                        <Font size="18.0" />
                    </font>
                </Label>
            </VBox>

        <StackPane prefHeight="495.0">
         <VBox alignment="CENTER_LEFT" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="box">
            <children>
                   <Label maxHeight="-Infinity" maxWidth="-Infinity" styleClass="text" text="Local Game">
                       <font>
                           <Font size="18.0" />
                       </font>
                   </Label>
               <VBox alignment="CENTER_LEFT">
                  <children>
                         <StackPane alignment="CENTER_LEFT" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="button-wrapper">
                             <Button fx:id="startLocalGameButton" maxHeight="28.0" maxWidth="-Infinity" onAction="#onLocalAction" text="Start Local Game" />
                         </StackPane>
                  </children>
                  <VBox.margin>
                     <Insets bottom="10.0" left="40.0" />
                  </VBox.margin>
               </VBox>
                   <Label maxHeight="-Infinity" maxWidth="-Infinity" styleClass="text" text="LAN Game">
                       <font>
                           <Font size="18.0" />
                       </font>
                   </Label>
               <VBox alignment="CENTER_LEFT">
                  <children>
                         <StackPane alignment="CENTER_LEFT" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="button-wrapper">
                             <Button fx:id="HostGameButton" maxHeight="-Infinity" maxWidth="-Infinity" mnemonicParsing="false" onAction="#onHostAction" text="Host Game" />
                         </StackPane>
                         <StackPane alignment="CENTER_RIGHT" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="button-wrapper">
                             <Button fx:id="JoinGameButton" alignment="CENTER_RIGHT" maxHeight="-Infinity" maxWidth="-Infinity" mnemonicParsing="false" onAction="#onJoinAction" text="Join Game" />
                         </StackPane>
                  </children>
                  <VBox.margin>
                     <Insets bottom="10.0" left="40.0" />
                  </VBox.margin>
               </VBox>
                   <Label maxHeight="-Infinity" maxWidth="-Infinity" styleClass="text" text="Others">
                       <font>
                           <Font size="18.0" />
                       </font>
                   </Label>
               <VBox alignment="CENTER_LEFT">
                  <children>
                         <StackPane alignment="CENTER_LEFT" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="button-wrapper">
                             <Button fx:id="BlockDesigner" maxHeight="-Infinity" maxWidth="-Infinity" mnemonicParsing="false" onAction="#onPartDesignerAciton" text="Block Designer" />
                         </StackPane>
                         <StackPane alignment="CENTER_LEFT" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="button-wrapper">
                             <Button maxHeight="-Infinity" maxWidth="-Infinity" mnemonicParsing="false" onAction="#onSettingsAction" text="Key Settings" />
                         </StackPane>
                  </children>
                  <VBox.margin>
                     <Insets left="40.0" />
                  </VBox.margin>
               </VBox>
               <VBox alignment="CENTER_LEFT">
                  <children>
                     <StackPane maxHeight="-Infinity" maxWidth="-Infinity" styleClass="button-wrapper">
                        <children>
                                <Button maxHeight="-Infinity" maxWidth="-Infinity" mnemonicParsing="false" onAction="#onExitAction" text="Back">
                              <StackPane.margin>
                                 <Insets top="20.0" />
                              </StackPane.margin>
                           </Button>
                        </children>
                     </StackPane>
                  </children>
                  <VBox.margin>
                     <Insets left="40.0" />
                  </VBox.margin>
               </VBox>
            </children>
            <padding>
               <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
         </VBox>
        </StackPane>
    </VBox>
</StackPane>
