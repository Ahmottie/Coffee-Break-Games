<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.Region?>

<StackPane fx:id="root" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="600.0" minWidth="800.0"
           styleClass="background" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="seda_project.control_alt_defeat.gamebox.Tetris.Controller.ResultScreen">
    <stylesheets>
        <URL value="@../../css/stylesheets/fontstyle.css"/>
        <URL value="@../../css/stylesheets/MenuStyle.css"/>
        <URL value="@../../css/stylesheets/TetrisMenu.css"/>
    </stylesheets>
    <VBox alignment="TOP_CENTER" fillWidth="false" layoutX="2.0">
        <HBox alignment="CENTER" spacing="10.0">
            <VBox.margin>
                <Insets top="10.0"/>
            </VBox.margin>
            <Region maxWidth="80.0" minWidth="80.0" prefWidth="80.0"/>
            <VBox fx:id="header" alignment="TOP_CENTER" fillWidth="false" maxHeight="-Infinity"
                  maxWidth="-Infinity" styleClass="box">
                <padding>
                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                </padding>
                <Label alignment="CENTER" contentDisplay="CENTER" maxHeight="-Infinity" maxWidth="-Infinity"
                       styleClass="headerText" text="COFFEE BREAK GAMES" textAlignment="CENTER"
                       textOverrun="CLIP">
                    <font>
                        <Font name="Arial Bold" size="24.0"/>
                    </font>
                </Label>
                <Label alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="normalText"
                       text="Main Menu">
                    <font>
                        <Font size="18.0"/>
                    </font>
                </Label>
            </VBox>
            <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="box">
                <ImageView fx:id="muteButton" fitHeight="80.0" fitWidth="80.0" onMouseClicked="#changeMute" pickOnBounds="true"
                           preserveRatio="true" styleClass="mute">
                    <Image url="@../../Images/others/mute.png"/>
                </ImageView>
            </VBox>
        </HBox>
        <StackPane prefHeight="475.0">
            <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="box">
                <GridPane maxHeight="-Infinity" maxWidth="-Infinity">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="240.0" minWidth="10.0"
                                           prefWidth="115.99999999999999"/>
                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="248.80003051757814" minWidth="10.0"
                                           prefWidth="120.0"/>
                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="222.8" minWidth="10.0"
                                           prefWidth="120.0"/>
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints maxHeight="-Infinity" vgrow="SOMETIMES"/>
                        <RowConstraints maxHeight="-Infinity" vgrow="SOMETIMES"/>
                        <RowConstraints maxHeight="-Infinity" vgrow="SOMETIMES"/>
                        <RowConstraints maxHeight="-Infinity" vgrow="SOMETIMES"/>
                        <RowConstraints maxHeight="-Infinity" vgrow="SOMETIMES"/>
                    </rowConstraints>
                    <padding>
                        <Insets left="15.0" right="15.0"/>
                    </padding>
                    <Label alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity"
                           styleClass="headerText" text="Game Result" GridPane.columnSpan="3"
                           GridPane.halignment="CENTER"/>
                    <Label fx:id="positionLooserLabel" text="Lines" GridPane.rowIndex="3"/>
                    <Label fx:id="LinesWinnerLabel" alignment="CENTER" contentDisplay="CENTER"
                           maxHeight="-Infinity" maxWidth="-Infinity" textAlignment="CENTER"
                           GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                    <Label text="Position" GridPane.rowIndex="4"/>
                    <Label fx:id="positionLabel1" alignment="CENTER" contentDisplay="CENTER"
                           maxHeight="-Infinity" maxWidth="-Infinity" text="Winner"
                           textAlignment="CENTER" GridPane.columnIndex="1" GridPane.halignment="CENTER"
                           GridPane.rowIndex="4"/>
                    <Label fx:id="positionWinnerLabel" text="Points" GridPane.rowIndex="2"/>
                    <Label fx:id="PointsWinnerLabel" alignment="CENTER" contentDisplay="CENTER"
                           maxHeight="-Infinity" maxWidth="-Infinity" textAlignment="CENTER"
                           GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    <Label fx:id="PointsLoserLabel" alignment="CENTER" maxHeight="-Infinity"
                           maxWidth="-Infinity" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
                    <Label fx:id="LinesLoserLabel" alignment="CENTER" maxHeight="-Infinity"
                           maxWidth="-Infinity" GridPane.columnIndex="2" GridPane.rowIndex="3"/>
                    <Label fx:id="positionLabel2" alignment="CENTER" maxHeight="-Infinity"
                           maxWidth="-Infinity" text="Loser" GridPane.columnIndex="2"
                           GridPane.halignment="CENTER" GridPane.rowIndex="4"/>
                    <Label text="Name" GridPane.rowIndex="1"/>
                    <Label fx:id="NameWinnerLabel" alignment="CENTER" maxHeight="-Infinity"
                           maxWidth="-Infinity" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    <Label fx:id="NameLoserLabel" alignment="CENTER" maxHeight="-Infinity"
                           maxWidth="-Infinity" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                </GridPane>
                <HBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity">
                    <StackPane styleClass="button-wrapper">
                        <Button fx:id="ExitButton" mnemonicParsing="false" onAction="#onExitGameAction"
                                text="Exit"/>
                    </StackPane>
                    <StackPane styleClass="button-wrapper">
                        <Button fx:id="playAgainButton" mnemonicParsing="false"
                                onAction="#onPlayAgainAction" text="Play Again"/>
                    </StackPane>
                </HBox>
            </VBox>
        </StackPane>
    </VBox>
</StackPane>