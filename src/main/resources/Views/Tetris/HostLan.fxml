                </VBox>
            <StackPane prefHeight="516.0" prefWidth="808.0">
               <children>
                  <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="250.0" prefWidth="350.0" styleClass="box">
                     <children>
                              <GridPane alignment="CENTER" prefHeight="97.0" prefWidth="350.0">
                                  <columnConstraints>
                                      <ColumnConstraints hgrow="SOMETIMES" maxWidth="109.0" minWidth="10.0" prefWidth="109.0" />
                                      <ColumnConstraints hgrow="SOMETIMES" maxWidth="94.0" minWidth="10.0" prefWidth="58.599999999999994" />
                                      <ColumnConstraints hgrow="SOMETIMES" maxWidth="144.0" minWidth="9.20000762939452" prefWidth="63.80000000000001" />
                                      <ColumnConstraints hgrow="SOMETIMES" maxWidth="185.0" minWidth="10.0" prefWidth="71.80000000000001" />
                                  </columnConstraints>
                                  <rowConstraints>
                                      <RowConstraints maxHeight="116.4" minHeight="10.0" prefHeight="70.4" vgrow="SOMETIMES" />
                                      <RowConstraints maxHeight="77.60000000000001" minHeight="10.0" prefHeight="77.60000000000001" vgrow="SOMETIMES" />
                                  </rowConstraints>
                                  <children>
                                      <Label alignment="CENTER" text="Your Name:" />
