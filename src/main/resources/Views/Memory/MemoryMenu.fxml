                    </children>
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
                </VBox>
            <StackPane maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="547.0">
               <children>
                        <GridPane maxHeight="-Infinity" maxWidth="-Infinity" styleClass="box" vgap="3.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity" percentWidth="30.0" />
