<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane fx:id="root" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="600.0" minWidth="800.0" styleClass="background" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="seda_project.control_alt_defeat.gamebox.Memory.Controller.MemoryMenu">
    <VBox alignment="TOP_CENTER">
        <fx:include source="../TopBar.fxml" />

            <VBox fx:id="header" alignment="TOP_CENTER" fillWidth="false" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="box">
                <padding>
                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                </padding>
                <Label alignment="CENTER" contentDisplay="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="headerText" text="COFFEE BREAK GAMES" textAlignment="CENTER" textOverrun="CLIP">
                    <font>
                        <Font name="Arial Bold" size="24.0" />
                    </font>
                </Label>
                <Label alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="normalText" text="Memory">
                    <font>
                        <Font size="18.0" />
                    </font>
                </Label>
            </VBox>

        <StackPane maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="495.0">
         <VBox maxHeight="-Infinity" maxWidth="-Infinity" styleClass="box">
            <children>
                   <Label maxHeight="-Infinity" maxWidth="-Infinity" styleClass="text" text="Local Game">
                       <font>
                           <Font size="18.0" />
                       </font>
                   </Label>
               <VBox>
                  <children>
                         <StackPane alignment="CENTER_LEFT" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="button-wrapper">
                             <Button maxHeight="-Infinity" maxWidth="-Infinity" mnemonicParsing="false" onAction="#onLocalAction" text="Local Game" />
                         </StackPane>
                  </children>
                  <padding>
                     <Insets bottom="10.0" left="40.0" />
                  </padding>
               </VBox>
                   <Label maxHeight="-Infinity" maxWidth="-Infinity" styleClass="text" text="LAN Game">
                       <font>
                           <Font size="18.0" />
                       </font>
                   </Label>
               <VBox>
                  <children>
                         <StackPane alignment="CENTER_LEFT" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="button-wrapper">
                             <Button mnemonicParsing="false" onAction="#onHostAction" text="Host Game" />
                         </StackPane>
                         <StackPane alignment="CENTER_LEFT" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="button-wrapper">
                             <Button mnemonicParsing="false" onAction="#onJoinAction" text="Join Game" />
                         </StackPane>
                  </children>
                  <padding>
                     <Insets bottom="15.0" left="40.0" />
                  </padding>
               </VBox>
               <VBox>
                  <children>
                         <StackPane alignment="CENTER_LEFT" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="button-wrapper">
                             <Button mnemonicParsing="false" onAction="#onExitAction" text="Back" />
                         </StackPane>
                  </children>
                  <padding>
                     <Insets left="40.0" />
                  </padding>
               </VBox>
            </children>
            <padding>
               <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
         </VBox>
        </StackPane>
    </VBox>
    <stylesheets>
        <URL value="@../../css/stylesheets/fontstyle.css" />
        <URL value="@../../css/stylesheets/MemoryMenu.css" />
        <URL value="@../../css/stylesheets/MenuStyle.css" />
    </stylesheets>
</StackPane>
