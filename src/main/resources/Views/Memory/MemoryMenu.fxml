                                <RowConstraints maxHeight="-Infinity" vgrow="SOMETIMES" />
                                <RowConstraints maxHeight="-Infinity" vgrow="SOMETIMES" />
                                <RowConstraints maxHeight="-Infinity" vgrow="SOMETIMES" />
                                <RowConstraints maxHeight="-Infinity" vgrow="SOMETIMES" />
                                <RowConstraints vgrow="SOMETIMES" />
                            </rowConstraints>
                            <children>
                                <Label maxHeight="-Infinity" maxWidth="-Infinity" styleClass="text" text="Local Game" GridPane.columnSpan="2">
                                    <font>
                                        <Font size="18.0" />
