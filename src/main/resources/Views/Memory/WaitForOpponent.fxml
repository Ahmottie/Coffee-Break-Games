<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.net.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane fx:id="root" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="600.0" minWidth="800.0" styleClass="background" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="seda_project.control_alt_defeat.gamebox.Memory.Controller.WaitForOpponent">
    <VBox alignment="TOP_CENTER">
        <fx:include source="../TopBar.fxml" />

            <VBox fx:id="header" alignment="TOP_CENTER" fillWidth="false" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="box">
                <padding>
                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                </padding>
                <Label alignment="CENTER" contentDisplay="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="headerText" text="COFFEE BREAK GAMES" textAlignment="CENTER" textOverrun="CLIP">
                    <font>
                        <Font name="Arial Bold" size="24.0" />
                    </font>
                </Label>
                <Label alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="normalText" text="Memory">
                    <font>
                        <Font size="18.0" />
                    </font>
                </Label>
            <Label text="Lobby" />
            </VBox>


        <StackPane prefHeight="475.0">
            <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="box">
                <padding>
                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                </padding>
                <GridPane hgap="5.0" maxHeight="-Infinity" maxWidth="-Infinity" vgap="5.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity" />
                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints maxHeight="-Infinity" vgrow="SOMETIMES" />
                        <RowConstraints maxHeight="-Infinity" vgrow="SOMETIMES" />
                        <RowConstraints maxHeight="-Infinity" vgrow="SOMETIMES" />
                        <RowConstraints maxHeight="-Infinity" vgrow="SOMETIMES" />
                        <RowConstraints maxHeight="-Infinity" vgrow="SOMETIMES" />
                        <RowConstraints maxHeight="-Infinity" vgrow="SOMETIMES" />
                    </rowConstraints>
                    <Label alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" text="Your Name: " />
                    <Label maxHeight="-Infinity" maxWidth="-Infinity" text="Host IP-Address: " GridPane.rowIndex="1" />
                    <Label maxHeight="-Infinity" maxWidth="-Infinity" text="Opponent Name: " GridPane.rowIndex="2" />
                    <Label maxHeight="-Infinity" maxWidth="-Infinity" text="Deck Size: " GridPane.rowIndex="3" />
                    <Label maxHeight="-Infinity" maxWidth="-Infinity" text="Match Size: " GridPane.rowIndex="4" />
                    <Label maxHeight="-Infinity" maxWidth="-Infinity" text="Stauts: " GridPane.rowIndex="5" />
                    <Label fx:id="yourNameLabel" alignment="CENTER" contentDisplay="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" textAlignment="CENTER" GridPane.columnIndex="1" />
                    <Label fx:id="hostIpAddressLabel" alignment="CENTER" contentDisplay="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" textAlignment="CENTER" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                    <Label fx:id="opponentNameLabel" alignment="CENTER" contentDisplay="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" textAlignment="CENTER" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                    <Label fx:id="deckSizeLabel" alignment="CENTER" contentDisplay="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" textAlignment="CENTER" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                    <Label fx:id="matchSizeLabel" alignment="CENTER" contentDisplay="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" textAlignment="CENTER" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                    <Label fx:id="statusLabel" alignment="CENTER" contentDisplay="CENTER" maxHeight="-Infinity" maxWidth="130.0" textAlignment="CENTER" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="5">
                        <styleClass>
                            <String fx:value="box" />
                            <String fx:value="information" />
                        </styleClass>
                        <padding>
                            <Insets left="5.0" right="5.0" />
                        </padding>
                    </Label>
                </GridPane>

                <HBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" spacing="10.0">
                    <padding>
                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                    </padding>
                    <StackPane maxHeight="-Infinity" maxWidth="-Infinity" styleClass="button-wrapper">
                        <Button maxHeight="-Infinity" maxWidth="-Infinity" mnemonicParsing="false" onAction="#onBackAction" text="Cancel" />
                    </StackPane>
                    <StackPane maxHeight="-Infinity" maxWidth="-Infinity" styleClass="button-wrapper">
                        <Button fx:id="startGameButton" maxHeight="-Infinity" maxWidth="-Infinity" mnemonicParsing="false" onAction="#onStartGameAction" text="Start Game" />
                    </StackPane>
                </HBox>
            </VBox>
        </StackPane>
    </VBox>
    <stylesheets>
        <URL value="@../../css/stylesheets/fontstyle.css" />
        <URL value="@../../css/stylesheets/MemoryMenu.css" />
        <URL value="@../../css/stylesheets/MenuStyle.css" />
    </stylesheets>
</StackPane>
