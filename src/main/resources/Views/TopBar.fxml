<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<HBox fx:id="topBar" alignment="CENTER_LEFT" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="30.0" style="-fx-background-color: #2b2b2b; -fx-background-radius: 16px 16px 0px 0px;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="seda_project.control_alt_defeat.gamebox.ui.TopBarController">
    <padding>
        <Insets left="15.0" right="10.0" />
    </padding>

    <Label styleClass="normalText" text="Coffee Break Games" textFill="WHITE" />

    <Region HBox.hgrow="ALWAYS" />
   <HBox alignment="CENTER" spacing="5.0">
       <ImageView fx:id="muteButton" fitHeight="15.0" fitWidth="15.0" onMouseClicked="#changeMute" pickOnBounds="true" preserveRatio="true" styleClass="mute">
           <Image url="@../Images/others/mute.png" />
       </ImageView>
      <HBox.margin>
         <Insets right="10.0" />
      </HBox.margin>
   </HBox>
    <HBox alignment="CENTER" spacing="5.0">
        <ImageView fitHeight="15.0" fitWidth="15.0" onMouseClicked="#closeWindow" pickOnBounds="true" preserveRatio="true" styleClass="mute">
            <Image url="@../Images/others/close.png" />
        </ImageView>
    </HBox>
</HBox>
