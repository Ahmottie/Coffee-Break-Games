<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>


<StackPane fx:id="root" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="600.0" minWidth="800.0" styleClass="background" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="seda_project.control_alt_defeat.gamebox.HexChess.Controller.ResultScreen">
    <VBox alignment="TOP_CENTER">
        <fx:include source="../TopBar.fxml" />

            <VBox fx:id="header" alignment="TOP_CENTER" fillWidth="false" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="box">
                <padding>
                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                </padding>
                <Label alignment="CENTER" contentDisplay="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="headerText" text="COFFEE BREAK GAMES" textAlignment="CENTER" textOverrun="CLIP">
                    <font>
                        <Font name="Arial Bold" size="24.0" />
                    </font>
                </Label>
                <Label alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="normalText" text="Hex Chess">
                    <font>
                        <Font size="18.0" />
                    </font>
                </Label>
            <Label text="Game Result" />
            </VBox>

        <StackPane prefHeight="475.0">
            <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="box">
                <HBox maxHeight="-Infinity" maxWidth="-Infinity">
                    <Label maxHeight="-Infinity" maxWidth="-Infinity" styleClass="normalText" text="Game Result: " />
                    <Label fx:id="resultLabel" styleClass="normalText" />
                </HBox>
                <GridPane hgap="10.0" maxHeight="-Infinity" maxWidth="-Infinity" vgap="4.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity" />
                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity" />
                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints maxHeight="-Infinity" vgrow="SOMETIMES" />
                        <RowConstraints maxHeight="-Infinity" vgrow="SOMETIMES" />
                    </rowConstraints>
                    <Label fx:id="p1NameLabel" maxHeight="-Infinity" maxWidth="-Infinity" text="Label" />
                    <Label fx:id="p2NameLabel" maxHeight="-Infinity" maxWidth="-Infinity" text="Label" GridPane.rowIndex="1" />
                    <Label fx:id="p1Score" text="0.0" GridPane.columnIndex="1" />
                    <Label fx:id="p2Score" text="0.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                    <Label fx:id="p1Awarded" text="0.0" GridPane.columnIndex="2" />
                    <Label fx:id="p2Awarded" text="0.0" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                </GridPane>
                <HBox alignment="CENTER">
                    <StackPane alignment="CENTER_LEFT" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="button-wrapper">
                        <Button maxHeight="-Infinity" maxWidth="-Infinity" mnemonicParsing="false" onAction="#onExitAction" text="Exit" />
                    </StackPane>
                    <StackPane alignment="CENTER_LEFT" layoutX="10.0" layoutY="10.0" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="button-wrapper">
                        <Button maxHeight="-Infinity" maxWidth="-Infinity" mnemonicParsing="false" onAction="#onPlayAgainAction" text="Play Again" />
                    </StackPane>
                </HBox>
            </VBox>
        </StackPane>
    </VBox>

    <stylesheets>
        <URL value="@../../css/stylesheets/fontstyle.css" />
        <URL value="@../../css/stylesheets/MainTheme.css" />
        <URL value="@../../css/stylesheets/MenuStyle.css" />
        <URL value="@../../css/stylesheets/HexChessMenu.css" />
    </stylesheets>
</StackPane>
