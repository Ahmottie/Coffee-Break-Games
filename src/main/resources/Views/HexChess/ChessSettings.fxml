<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.Double?>
<?import java.lang.String?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ColorPicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.shape.Polygon?>
<?import javafx.scene.text.Font?>

<StackPane fx:id="root" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="600.0" minWidth="800.0"
           styleClass="background" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="seda_project.control_alt_defeat.gamebox.HexChess.Controller.ChessSettings">
    <stylesheets>
        <URL value="@../../css/stylesheets/fontstyle.css"/>
        <URL value="@../../css/stylesheets/MenuStyle.css"/>
        <URL value="@../../css/stylesheets/HexChessMenu.css"/>
    </stylesheets>
    <VBox alignment="TOP_CENTER" fillWidth="false" layoutX="2.0">
        <HBox alignment="CENTER" spacing="10.0">
            <VBox.margin>
                <Insets top="10.0"/>
            </VBox.margin>
            <Region maxWidth="80.0" minWidth="80.0" prefWidth="80.0"/>
            <VBox fx:id="header" alignment="TOP_CENTER" fillWidth="false" maxHeight="-Infinity"
                  maxWidth="-Infinity" styleClass="box">
                <padding>
                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                </padding>
                <Label alignment="CENTER" contentDisplay="CENTER" maxHeight="-Infinity" maxWidth="-Infinity"
                       styleClass="headerText" text="COFFEE BREAK GAMES" textAlignment="CENTER"
                       textOverrun="CLIP">
                    <font>
                        <Font name="Arial Bold" size="24.0"/>
                    </font>
                </Label>
                <Label alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="normalText"
                       text="Main Menu">
                    <font>
                        <Font size="18.0"/>
                    </font>
                </Label>
            </VBox>
            <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="box">
                <ImageView fx:id="muteButton" fitHeight="80.0" fitWidth="80.0" pickOnBounds="true"
                           preserveRatio="true" styleClass="mute" onMouseClicked="#changeMute">
                    <Image url="@../../Images/others/mute.png"/>
                </ImageView>
            </VBox>
        </HBox>
        <StackPane fx:id="stackPane" prefHeight="495.0">
            <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" spacing="10.0" styleClass="box">
                <padding>
                    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
                </padding>
                <HBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" spacing="20.0">
                    <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity">
                        <padding>
                            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                        </padding>
                        <styleClass>
                            <String fx:value="box"/>
                            <String fx:value="error"/>
                        </styleClass>
                        <Label styleClass="normalText" text="Player 1"/>
                        <ColorPicker fx:id="p1ColorPicker" maxHeight="-Infinity"
                                     maxWidth="-Infinity" onAction="#onP1ColorAction"/>
                        <HBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity">
                            <ImageView fx:id="p1Pawn" fitHeight="75" fitWidth="75"
                                       pickOnBounds="true" preserveRatio="true">
                                <Image url="@../../Images/HexChess/White/white-pawn.png"/>
                            </ImageView>
                            <ImageView fx:id="p1Rook" fitHeight="75" fitWidth="75"
                                       pickOnBounds="true" preserveRatio="true">
                                <Image url="@../../Images/HexChess/White/white-rook.png"/>
                            </ImageView>
                            <ImageView fx:id="p1Knight" fitHeight="75" fitWidth="75"
                                       pickOnBounds="true" preserveRatio="true">
                                <Image url="@../../Images/HexChess/White/white-knight.png"/>
                            </ImageView>
                        </HBox>
                        <HBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity">
                            <ImageView fx:id="p1Bishop" fitHeight="75" fitWidth="75"
                                       pickOnBounds="true" preserveRatio="true">
                                <Image url="@../../Images/HexChess/White/white-bishop.png"/>
                            </ImageView>
                            <ImageView fx:id="p1Queen" fitHeight="75" fitWidth="75"
                                       pickOnBounds="true" preserveRatio="true">
                                <Image url="@../../Images/HexChess/White/white-queen.png"/>
                            </ImageView>
                            <ImageView fx:id="p1King" fitHeight="75" fitWidth="75"
                                       pickOnBounds="true" preserveRatio="true">
                                <Image url="@../../Images/HexChess/White/white-king.png"/>
                            </ImageView>
                        </HBox>
                    </VBox>
                    <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity">
                        <padding>
                            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                        </padding>
                        <styleClass>
                            <String fx:value="box"/>
                            <String fx:value="ready"/>
                        </styleClass>
                        <Label styleClass="normalText" text="Player 2"/>
                        <ColorPicker fx:id="p2ColorPicker" onAction="#onP2ColorAction">
                            <value>
                                <Color/>
                            </value>
                        </ColorPicker>
                        <HBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity">
                            <ImageView fx:id="p2Pawn" fitHeight="75" fitWidth="75"
                                       pickOnBounds="true" preserveRatio="true">
                                <Image url="@../../Images/HexChess/Black/black-pawn.png"/>
                            </ImageView>
                            <ImageView fx:id="p2Rook" fitHeight="75" fitWidth="75"
                                       pickOnBounds="true" preserveRatio="true">
                                <Image url="@../../Images/HexChess/Black/black-rook.png"/>
                            </ImageView>
                            <ImageView fx:id="p2Knight" fitHeight="75" fitWidth="75"
                                       pickOnBounds="true" preserveRatio="true">
                                <Image url="@../../Images/HexChess/Black/black-knight.png"/>
                            </ImageView>
                        </HBox>
                        <HBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity">
                            <ImageView fx:id="p2Bishop" fitHeight="75" fitWidth="75"
                                       pickOnBounds="true" preserveRatio="true">
                                <Image url="@../../Images/HexChess/Black/black-bishop.png"/>
                            </ImageView>
                            <ImageView fx:id="p2Queen" fitHeight="75" fitWidth="75"
                                       pickOnBounds="true" preserveRatio="true">
                                <Image url="@../../Images/HexChess/Black/black-queen.png"/>
                            </ImageView>
                            <ImageView fx:id="p2King" fitHeight="75" fitWidth="75"
                                       pickOnBounds="true" preserveRatio="true">
                                <Image url="@../../Images/HexChess/Black/black-king.png"/>
                            </ImageView>
                        </HBox>
                    </VBox>
                </HBox>
                <HBox maxHeight="-Infinity" maxWidth="-Infinity" spacing="20.0">
                    <VBox alignment="CENTER" spacing="10.0">
                        <Label styleClass="normalText" text="Dark Tiles"/>
                        <ColorPicker fx:id="darkTilesColorPicker" onAction="#onDarkTileAction"/>
                        <Polygon fx:id="darkPolygon">
                            <points>
                                <Double fx:value="-27.0"/>
                                <Double fx:value="0.0"/>
                                <Double fx:value="-13.5"/>
                                <Double fx:value="23.38"/>
                                <Double fx:value="13.5"/>
                                <Double fx:value="23.38"/>
                                <Double fx:value="27.0"/>
                                <Double fx:value="0.0"/>
                                <Double fx:value="13.5"/>
                                <Double fx:value="-23.38"/>
                                <Double fx:value="-13.5"/>
                                <Double fx:value="-23.38"/>
                            </points>
                        </Polygon>
                    </VBox>
                    <VBox alignment="CENTER" spacing="10.0">
                        <Label styleClass="normalText" text="Normal Tiles"/>
                        <ColorPicker fx:id="normalTilesColorPicker" onAction="#onNormalTileAction"/>
                        <Polygon fx:id="normalPolygon">
                            <points>
                                <Double fx:value="-27.0"/>
                                <Double fx:value="0.0"/>
                                <Double fx:value="-13.5"/>
                                <Double fx:value="23.38"/>
                                <Double fx:value="13.5"/>
                                <Double fx:value="23.38"/>
                                <Double fx:value="27.0"/>
                                <Double fx:value="0.0"/>
                                <Double fx:value="13.5"/>
                                <Double fx:value="-23.38"/>
                                <Double fx:value="-13.5"/>
                                <Double fx:value="-23.38"/>
                            </points>
                        </Polygon>
                    </VBox>
                    <VBox alignment="CENTER" spacing="10.0">
                        <Label styleClass="normalText" text="Light Tiles"/>
                        <ColorPicker fx:id="lightTilesColorPicker" onAction="#onLightTileaAction"/>
                        <Polygon fx:id="lightPolygon">
                            <points>
                                <Double fx:value="-27.0"/>
                                <Double fx:value="0.0"/>
                                <Double fx:value="-13.5"/>
                                <Double fx:value="23.38"/>
                                <Double fx:value="13.5"/>
                                <Double fx:value="23.38"/>
                                <Double fx:value="27.0"/>
                                <Double fx:value="0.0"/>
                                <Double fx:value="13.5"/>
                                <Double fx:value="-23.38"/>
                                <Double fx:value="-13.5"/>
                                <Double fx:value="-23.38"/>
                            </points>
                        </Polygon>
                    </VBox>
                </HBox>
                <HBox maxHeight="-Infinity" maxWidth="-Infinity" spacing="20.0">
                    <StackPane maxHeight="-Infinity" maxWidth="-Infinity" styleClass="button-wrapper">
                        <Button maxHeight="-Infinity" maxWidth="-Infinity" mnemonicParsing="false"
                                onAction="#onBackAction" text="Back"/>
                    </StackPane>
                    <StackPane maxHeight="-Infinity" maxWidth="-Infinity" styleClass="button-wrapper">
                        <Button maxHeight="-Infinity" maxWidth="-Infinity" mnemonicParsing="false"
                                onAction="#onSaveAction" text="Save"/>
                    </StackPane>
                    <StackPane maxHeight="-Infinity" maxWidth="-Infinity" styleClass="button-wrapper">
                        <Button maxHeight="-Infinity" maxWidth="-Infinity" mnemonicParsing="false"
                                onAction="#onDefaultAction" text="Default"/>
                    </StackPane>
                </HBox>
            </VBox>
        </StackPane>
    </VBox>
    <ImageView fx:id="p2Duck" fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true"
               visible="false">
        <Image url="@../../Images/HexChess/Black/black-duck.png"/>
    </ImageView>
    <ImageView fx:id="p1Duck" fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true"
               visible="false">
        <Image url="@../../Images/HexChess/White/white-duck.png"/>
    </ImageView>
</StackPane>