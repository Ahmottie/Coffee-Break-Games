<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import seda_project.control_alt_defeat.gamebox.ui.ToggleSwitch?>

<StackPane fx:id="root" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="600.0" minWidth="800.0" styleClass="background" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="seda_project.control_alt_defeat.gamebox.HexChess.Controller.LocalGameConfiguration">
    <VBox alignment="TOP_CENTER">
        <fx:include source="../TopBar.fxml" />

            <VBox fx:id="header" alignment="TOP_CENTER" fillWidth="false" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="box">
                <padding>
                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                </padding>
                <Label alignment="CENTER" contentDisplay="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="headerText" text="COFFEE BREAK GAMES" textAlignment="CENTER" textOverrun="CLIP">
                    <font>
                        <Font name="Arial Bold" size="24.0" />
                    </font>
                </Label>
                <Label alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="normalText" text="Hex Chess">
                    <font>
                        <Font size="18.0" />
                    </font>
                </Label>
            <Label text="Local Game Configuration" />
            </VBox>

        <StackPane prefHeight="475.0">
            <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="box">
            <Label styleClass="normalText" text="Player 1">
               <padding>
                  <Insets bottom="5.0" />
               </padding>
            </Label>
                <HBox alignment="CENTER_LEFT">
                    <Label text="Is Bot: " />
                    <ToggleSwitch fx:id="isP1Bot" maxHeight="-Infinity" maxWidth="-Infinity" />
                </HBox>
                <HBox alignment="CENTER_LEFT">
                    <Label maxHeight="-Infinity" maxWidth="-Infinity" text="Player 1 Name: " />
                    <TextField fx:id="player1TF" maxHeight="-Infinity" maxWidth="-Infinity" promptText="Insert Player 1 Name " />
                </HBox>
            <Label styleClass="normalText" text="Player 2">
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
               <padding>
                  <Insets bottom="5.0" />
               </padding>
            </Label>
                <HBox alignment="CENTER_LEFT" layoutX="21.0" layoutY="215.0">
                    <Label text="Is Bot: " />
                    <ToggleSwitch fx:id="isP2Bot" maxHeight="-Infinity" maxWidth="-Infinity" />
                </HBox>
                <HBox alignment="CENTER_LEFT">
                    <Label maxHeight="-Infinity" maxWidth="-Infinity" text="Player 2 Name" />
                    <TextField fx:id="player2TF" maxHeight="-Infinity" maxWidth="-Infinity" promptText="Insert Player 2 Name" />
                </HBox>
                <StackPane maxHeight="-Infinity" maxWidth="-Infinity" styleClass="button-wrapper">
                    <Button mnemonicParsing="false" onAction="#onCustomBoardAction" text="Use Custom Board">
                  <StackPane.margin>
                     <Insets top="10.0" />
                  </StackPane.margin></Button>
                </StackPane>
                <Label fx:id="statusLabel" maxHeight="-Infinity" maxWidth="270.0" visible="false" wrapText="true">
                    <styleClass>
                        <String fx:value="box" />
                        <String fx:value="error" />
                    </styleClass>
                    <padding>
                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                    </padding>
                </Label>
                <HBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity">
                    <StackPane styleClass="button-wrapper">
                        <Button alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" onAction="#onBackAction" text="Back">
                            <HBox.margin>
                                <Insets right="10.0" />
                            </HBox.margin>
                        </Button>
                    </StackPane>
                    <StackPane styleClass="button-wrapper">
                        <Button alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" onAction="#onStartAction" text="Start Game">
                            <HBox.margin>
                                <Insets left="10.0" />
                            </HBox.margin>
                        </Button>
                    </StackPane>
                    <VBox.margin>
                        <Insets />
                    </VBox.margin>
                </HBox>
            <padding>
               <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            </VBox>
        </StackPane>
    </VBox>

    <stylesheets>
        <URL value="@../../css/stylesheets/fontstyle.css" />
        <URL value="@../../css/stylesheets/MenuStyle.css" />
        <URL value="@../../css/stylesheets/HexChessMenu.css" />
    </stylesheets>
</StackPane>
